# Privacy Filter Configuration
# Copy to .env.privacy and adjust as needed

# Privacy Filter Service URL
PRIVACY_FILTER_URL=http://localhost:8001

# Enable/disable PII filtering
PRIVACY_FILTER_ENABLED=true

# Categories to filter (comma-separated)
# Available: account_number, address, email, person, phone, url, date, secret
PRIVACY_FILTER_CATEGORIES=account_number,address,email,person,phone,url,secret

# Replacement text for filtered content
PRIVACY_FILTER_REPLACEMENT=[REDACTED]

# Keep original length with asterisks (true/false)
PRIVACY_FILTER_KEEP_LENGTH=false

# Batch size for processing multiple texts
PRIVACY_FILTER_BATCH_SIZE=10

# Timeout for filter requests (seconds)
PRIVACY_FILTER_TIMEOUT=10

# Fallback behavior when filter is unavailable
# Options: "mask" (basic regex masking), "pass" (pass through), "error" (return error)
PRIVACY_FILTER_FALLBACK=mask

# Log level for privacy filter
# Options: debug, info, warn, error
PRIVACY_FILTER_LOG_LEVEL=info

# Game-specific settings
# Filter player names in logs (true/false)
FILTER_PLAYER_NAMES=true

# Filter location names in logs (true/false)
FILTER_LOCATION_NAMES=false

# Filter game commands in logs (true/false)
FILTER_COMMANDS=false

# Filter combat details in logs (true/false)
FILTER_COMBAT_DETAILS=false