# Dark Pawns Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit actual secrets to version control!

# ========== SECURITY SETTINGS ==========
# Generate secure random values for these:
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_JWT_SECRET_MIN_32_CHARS
ENCRYPTION_KEY=REPLACE_WITH_SECURE_RANDOM_ENCRYPTION_KEY_32_BYTES

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment (development/production)
ENVIRONMENT=development

# ========== DATABASE ==========
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@postgres/darkpawns?sslmode=disable
REDIS_URL=redis://redis:6379/0

# ========== AI AGENT ==========
AI_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY

# ========== EXTERNAL API KEYS (optional) ==========
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MEM0_API_KEY=your_mem0_api_key_here

# ========== SERVER SETTINGS ==========
PORT=8080
WORLD_DIR=./lib

# ========== TLS/HTTPS (production only) ==========
USE_TLS=false
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem