<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Game on Dark Pawns Documentation</title><link>https://darkpawns.labz0rz.com/docs/categories/game/</link><description>Recent content in Game on Dark Pawns Documentation</description><generator>Hugo</generator><language>en-us</language><lastBuildDate>Wed, 22 Apr 2026 00:00:00 +0000</lastBuildDate><atom:link href="https://darkpawns.labz0rz.com/docs/categories/game/index.xml" rel="self" type="application/rss+xml"/><item><title>Interactive Map</title><link>https://darkpawns.labz0rz.com/docs/game/map/</link><pubDate>Wed, 22 Apr 2026 00:00:00 +0000</pubDate><guid>https://darkpawns.labz0rz.com/docs/game/map/</guid><description>&lt;h1 id="interactive-dark-pawns-map">Interactive Dark Pawns Map&lt;/h1>
&lt;p>Explore the world of Dark Pawns with this interactive map. The map shows all areas, rooms, and connections in the game world.&lt;/p>
&lt;h2 id="features">Features&lt;/h2>
&lt;ul>
&lt;li>&lt;strong>Zoom &amp;amp; Pan&lt;/strong>: Navigate the map with mouse or touch controls&lt;/li>
&lt;li>&lt;strong>Room Search&lt;/strong>: Find specific rooms by name or description&lt;/li>
&lt;li>&lt;strong>Area Overview&lt;/strong>: Switch between different game areas&lt;/li>
&lt;li>&lt;strong>Room Details&lt;/strong>: Click on any room to see detailed information&lt;/li>
&lt;li>&lt;strong>Pathfinding&lt;/strong>: Find routes between rooms&lt;/li>
&lt;li>&lt;strong>Export Options&lt;/strong>: Download map as PNG or SVG&lt;/li>
&lt;/ul>
&lt;h2 id="map-interface">Map Interface&lt;/h2>
&lt;div id="map-container" style="width: 100%; height: 600px; border: 1px solid #333; background: #1a1a1a; position: relative;">
 &lt;div id="map-loading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #ccc; font-size: 18px;">
 Loading interactive map...
 &lt;/div>
 &lt;canvas id="map-canvas" style="display: none;">&lt;/canvas>
&lt;/div>
&lt;div id="map-controls" style="margin-top: 20px; padding: 15px; background: #2a2a2a; border-radius: 5px;">
 &lt;div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
 &lt;button id="zoom-in" class="button is-small is-primary">Zoom In&lt;/button>
 &lt;button id="zoom-out" class="button is-small is-primary">Zoom Out&lt;/button>
 &lt;button id="reset-view" class="button is-small is-info">Reset View&lt;/button>
 &lt;div style="flex-grow: 1;">&lt;/div>
 &lt;input id="room-search" type="text" class="input is-small" placeholder="Search rooms..." style="width: 200px;">
 &lt;button id="search-btn" class="button is-small is-success">Search&lt;/button>
 &lt;/div>
 &lt;div id="search-results" style="margin-top: 10px; display: none;">
 &lt;div class="box" style="background: #333; color: #ccc;">
 &lt;h4 style="margin-bottom: 10px;">Search Results&lt;/h4>
 &lt;div id="results-list">&lt;/div>
 &lt;/div>
 &lt;/div>
&lt;/div>
&lt;div id="room-details" class="box" style="margin-top: 20px; background: #2a2a2a; color: #ccc; display: none;">
 &lt;h3 id="room-title">Room Details&lt;/h3>
 &lt;div id="room-content">
 &lt;p>Select a room on the map to see details.&lt;/p></description></item></channel></rss>