:80 {
    root * /srv/darkpawns
    encode gzip
    file_server
    
    @fingerprinted path *.css /css/* /js/*
    header @fingerprinted Cache-Control "public, max-age=31536000, immutable"
    
    @htmlfile path *.html /
    header @htmlfile Cache-Control "public, max-age=300"
    
    @wants_markdown {
        header Accept *text/markdown*
    }
    
    handle @wants_markdown {
        root * /srv/darkpawns
        try_files {path}/index.md {path}.md 404
        header Content-Type "text/markdown; charset=utf-8"
        header Access-Control-Allow-Origin "*"
        file_server
    }
    
    handle {
        root * /srv/darkpawns
        try_files {path} {path}/index.html {path}.html /404.html
        header Link "{uri}index.md; rel=alternate; type=text/markdown"
        file_server
    }
    
    handle /ws {
        reverse_proxy localhost:8080
    }
    
    handle /api/* {
        reverse_proxy localhost:8080
    }
    
    handle /health {
        reverse_proxy localhost:8080
    }
    
    handle /metrics {
        reverse_proxy localhost:8080
    }
}
